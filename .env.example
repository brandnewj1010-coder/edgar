# ========== Vercel / npx vercel dev (서버) ==========
# 로컬: .env.local 파일을 만들고 GEMINI_API_KEY 만 넣어도 됨 (Git 무시됨)
# 실행: npm run dev:vercel  → 브라우저는 안내 URL (보통 localhost:3000)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ========== Vite (클라이언트 번들에 포함 — anon 키만 사용) ==========
# Supabase 대시보드 → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vercel 대시보드: Project → Settings → Environment Variables에
# 위 이름 그대로 추가 후 재배포 (Preview/Production 모두)

# 데모 UI만: VITE_USE_DEMO=1

# Supabase SQL: supabase/migrations/*.sql 을 SQL Editor에서 순서대로 실행
# (search_history → analysis_reports)
